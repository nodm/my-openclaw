# Google AI API key (GCP console → APIs & Services → Credentials, or Google AI Studio)
GEMINI_API_KEY=REPLACE_ME

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=REPLACE_ME

# Random secret — generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME

# Keyring password for secure credential storage (WhatsApp session etc.)
# Generate with: openssl rand -hex 32
GOG_KEYRING_PASSWORD=REPLACE_ME

# Telegram user IDs (find yours via @userinfobot)
YOUR_TG_ID=REPLACE_ME
HONEY_TG_ID=REPLACE_ME

# Discord bot token from Developer Portal
DISCORD_BOT_TOKEN=REPLACE_ME
# Discord user/server IDs (enable Developer Mode in Discord to copy)
YOUR_DISCORD_ID=REPLACE_ME
DISCORD_SERVER_ID=REPLACE_ME

# Gateway bind mode — loopback (recommended with Tailscale Serve)
OPENCLAW_GATEWAY_BIND=loopback

# Model tiers (Google AI via Generative Language API)
MODEL_INTERACTIVE=google/gemini-2.5-flash
MODEL_MEDIUM=google/gemini-2.5-flash
MODEL_REASONING=google/gemini-2.5-pro
MODEL_SIMPLE=google/gemini-2.5-flash-lite
