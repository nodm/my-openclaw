// ~/.openclaw/openclaw.json
// Copy to server: scp openclaw.json root@<serverIp>:/root/.openclaw/openclaw.json
// Then restart:   ssh root@<serverIp> "openclaw daemon restart"
{
  gateway: {
    mode: "local",
    controlUi: {
      allowedOrigins: ["http://localhost:18789", "http://127.0.0.1:18789", "https://*"],
    },
    reload: { mode: "hybrid" },
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
    },
    list: [
      {
        id: "main",
        model: "${MODEL_INTERACTIVE}",
        workspace: "~/.openclaw/workspace",
        identity: {
          name: "Clawd",
          theme: "helpful personal assistant",
          emoji: "🦞",
        },
      },
      {
        id: "honey",
        model: "${MODEL_INTERACTIVE}",
        workspace: "~/.openclaw/workspace-honey",
        identity: {
          name: "Clawd",
          theme: "helpful personal assistant",
          emoji: "🦞",
        },
      },
      {
        id: "cron",
        model: "${MODEL_SIMPLE}",
        workspace: "~/.openclaw/workspace",
        identity: {
          name: "CronClawd",
          theme: "background task executor",
          emoji: "⏰",
        },
      },
    ],
  },

  bindings: [
    {
      match: { channel: "telegram", peer: { kind: "dm", id: "${YOUR_TG_ID}" } },
      agentId: "main",
    },
    {
      match: { channel: "telegram", peer: { kind: "dm", id: "${HONEY_TG_ID}" } },
      agentId: "honey",
    },
    {
      match: { channel: "discord", peer: { kind: "dm", id: "${YOUR_DISCORD_ID}" } },
      agentId: "main",
    },
  ],

  plugins: {
    entries: {
      microsoft: {
        enabled: true,
      },
      google: {
        enabled: true,
      },
    },
  },

  messages: {
    tts: {
      auto: "off",
      provider: "microsoft",
      providers: {
        microsoft: {
          enabled: true,
          outputFormat: "ogg-24khz-16bit-mono-opus",
        },
      },
    },
  },

  commands: {
    native: "auto",
    nativeSkills: "auto",
    restart: true,
    ownerDisplay: "raw",
  },

  channels: {
    telegram: {
      enabled: true,
      dmPolicy: "pairing",
      allowFrom: ["${YOUR_TG_ID}", "${HONEY_TG_ID}"],
      botToken: "${TELEGRAM_BOT_TOKEN}",
      groupPolicy: "allowlist",
      streaming: { mode: "partial" },
    },
    discord: {
      enabled: true,
      dmPolicy: "pairing",
      allowFrom: ["${YOUR_DISCORD_ID}"],
      token: "${DISCORD_BOT_TOKEN}",
      groupPolicy: "allowlist",
      streaming: { mode: "off" },
    },
  },
}
